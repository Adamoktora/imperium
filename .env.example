# ============================================
# Imperium - Environment Configuration
# ============================================
# Copy this file: cp .env.example .env
# Then fill in your values below.

# Groq AI (required for: analyze, ai-rebalance, watch mode)
# Get free API key: https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here

# MoonPay CLI wallet name
# Create one: moonpay wallet create --name imperium
MOONPAY_WALLET=imperium

# Default blockchain for operations
# Options: base, ethereum, polygon, arbitrum, optimism, solana
DEFAULT_CHAIN=base
